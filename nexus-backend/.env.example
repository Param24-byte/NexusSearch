# NexusSearch Backend — Environment Variables
# Copy this to .env and fill in your values. Never commit .env to git.

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]

# ── Neo4j AuraDB ───────────────────────────────────────────────────────────────
# Get from: https://console.neo4j.io → your instance → Connect
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-aura-password-here

# ── Serper Search API ──────────────────────────────────────────────────────────
# Get from: https://serper.dev — free 2,500 queries, no credit card required
# 1. Go to serper.dev → Sign up → Dashboard → API Key
SERPER_API_KEY=your_serper_key_here
SERPER_RESULTS_COUNT=8

# ── Gemini ─────────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_your_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# ── Pipeline Tuning ────────────────────────────────────────────────────────────
SCRAPE_TIMEOUT_SECONDS=10
MAX_CONTENT_CHARS=8000
MAX_CONCURRENT_SCRAPES=5
